generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  DRAFT
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum PaymentStatus {
  UNPAID
  PAID
  CANCELLED
}

enum ApplicationStatus {
  NEW
  CONTACTED
  WAITING
  FORWARDED
  REJECTED
  HIRED
}

enum ApplicationTag {
  SUITABLE
  FORWARDED_TO_COMPANY
  WAITING
  POSITION_FILLED
}

enum AdPlacementStatus {
  AVAILABLE
  RESERVED
  ACTIVE
  PAUSED
  EXPIRED
}

enum AdProductType {
  PAID_AD
  JALOVEC
  PARTNER_OF_WEEK
}

enum AdminRole {
  ADMIN
  EDITOR
  SALES
  VIEWER
}

enum AdminUserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum ClientUserRole {
  OWNER
  HR
  BILLING
}

enum ClientUserStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum JobSource {
  ADMIN
  CLIENT
}

enum JobReviewStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
}

model City {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  region    String?
  isDefault Boolean   @default(false)
  isActive  Boolean   @default(true)
  sortOrder Int       @default(100)
  jobs      JobPost[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  isActive  Boolean   @default(true)
  sortOrder Int       @default(100)
  jobs      JobPost[]
}

model Education {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  isActive  Boolean   @default(true)
  sortOrder Int       @default(100)
  jobs      JobPost[]
}

model EmploymentType {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  isActive  Boolean   @default(true)
  sortOrder Int       @default(100)
  jobs      JobPost[]
}

model Suitability {
  id        String           @id @default(cuid())
  name      String           @unique
  slug      String           @unique
  isActive  Boolean          @default(true)
  sortOrder Int              @default(100)
  jobs      JobSuitability[]
}

model Company {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  ico         String?
  logoUrl     String?
  brandColor  String?
  contactName String?
  email       String?
  phone       String?
  address     String?
  note        String?
  jobs        JobPost[]
  invoices    Invoice[]
  clientUsers ClientUser[]
  activityLogs ActivityLog[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PricingPackage {
  id          String    @id @default(cuid())
  name        String
  description String?
  durationDays Int
  priceCzk    Int
  highlightColor String?
  isTopPlacement Boolean   @default(false)
  topDays      Int?
  isActive    Boolean   @default(true)
  jobs        JobPost[]
  invoices    Invoice[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model JobPost {
  id             String           @id @default(cuid())
  title          String
  slug           String           @unique
  shortIntro     String
  description    String
  requirements   String?
  benefits       String?
  contactEmail   String?
  contactPhone   String?
  previewImageUrl String?
  detailImageUrl  String?
  flyerUrl        String?
  showImageInList Boolean          @default(false)
  showSalaryInPreview Boolean      @default(true)
  showOnHomepage Boolean           @default(false)
  salaryMinCzk   Int?
  salaryMaxCzk   Int?
  highlightColor String?
  isTop          Boolean          @default(false)
  topUntil       DateTime?
  status         JobStatus        @default(DRAFT)
  activeFrom     DateTime?
  activeUntil    DateTime?
  renewedAt      DateTime?
  views          Int              @default(0)
  source         JobSource        @default(ADMIN)
  reviewStatus   JobReviewStatus  @default(APPROVED)
  submittedAt    DateTime?
  reviewedAt     DateTime?
  reviewNote     String?
  submittedByClientId String?
  reviewedByAdminId   String?
  companyId      String
  cityId         String
  categoryId     String
  educationId    String?
  employmentTypeId String
  packageId      String?
  company        Company          @relation(fields: [companyId], references: [id])
  city           City             @relation(fields: [cityId], references: [id])
  category       Category         @relation(fields: [categoryId], references: [id])
  education      Education?       @relation(fields: [educationId], references: [id])
  employmentType EmploymentType   @relation(fields: [employmentTypeId], references: [id])
  package        PricingPackage?  @relation(fields: [packageId], references: [id])
  submittedByClient ClientUser?    @relation(fields: [submittedByClientId], references: [id])
  reviewedByAdmin   AdminUser?     @relation(fields: [reviewedByAdminId], references: [id])
  suitabilities  JobSuitability[]
  applications   Application[]
  invoices       Invoice[]
  reviewComments JobReviewComment[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status, activeUntil])
  @@index([source, reviewStatus, submittedAt])
  @@index([status, isTop, renewedAt])
  @@index([status, showOnHomepage, isTop, renewedAt])
  @@index([status, createdAt])
  @@index([companyId, status])
  @@index([submittedByClientId, reviewStatus])
  @@index([cityId, categoryId])
  @@index([salaryMinCzk, salaryMaxCzk])
}

model JobSuitability {
  jobId         String
  suitabilityId String
  job          JobPost      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  suitability  Suitability  @relation(fields: [suitabilityId], references: [id], onDelete: Cascade)

  @@id([jobId, suitabilityId])
}

model Application {
  id          String            @id @default(cuid())
  jobId       String
  name        String
  email       String
  phone       String?
  message     String
  consentGdpr Boolean
  ipHash      String?
  status      ApplicationStatus @default(NEW)
  tags        ApplicationTag[]  @default([])
  internalNote String?
  job         JobPost           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  communications ApplicationCommunication[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([jobId, status])
}

model ApplicationCommunication {
  id            String      @id @default(cuid())
  applicationId String
  channel       String
  direction     String
  subject       String?
  body          String
  actorEmail    String?
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
}

model Invoice {
  id          String        @id @default(cuid())
  companyId   String
  jobId       String?
  packageId   String?
  number      String?
  amountCzk   Int
  status      PaymentStatus @default(UNPAID)
  issuedAt    DateTime      @default(now())
  paidAt      DateTime?
  note        String?
  company     Company       @relation(fields: [companyId], references: [id])
  job         JobPost?      @relation(fields: [jobId], references: [id])
  package     PricingPackage? @relation(fields: [packageId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, issuedAt])
}

model AdminUser {
  id                  String             @id @default(cuid())
  email               String             @unique
  username            String?            @unique
  passwordHash        String
  name                String
  firstName           String?
  lastName            String?
  role                AdminRole          @default(EDITOR)
  status              AdminUserStatus    @default(ACTIVE)
  forcePasswordChange Boolean            @default(false)
  lastLoginAt         DateTime?
  failedLoginCount    Int                @default(0)
  lockedUntil         DateTime?
  resetTokens         PasswordResetToken[]
  reviewedJobs        JobPost[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model ClientUser {
  id               String           @id @default(cuid())
  email            String           @unique
  passwordHash     String
  name             String
  phone            String?
  role             ClientUserRole   @default(OWNER)
  status           ClientUserStatus @default(ACTIVE)
  lastLoginAt      DateTime?
  failedLoginCount Int              @default(0)
  lockedUntil      DateTime?
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id])
  submittedJobs    JobPost[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([companyId])
  @@index([status])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorId     String?
  actorType   String   @default("admin")
  actorEmail  String?
  companyId   String?
  action      String
  entityType  String
  entityId    String?
  summary     String
  metadata    Json?
  createdAt   DateTime @default(now())
  company     Company? @relation(fields: [companyId], references: [id])

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([companyId, createdAt])
}

model JobReviewComment {
  id          String   @id @default(cuid())
  jobId       String
  authorType  String
  authorEmail String?
  message     String
  createdAt   DateTime @default(now())
  job         JobPost  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model PublicationIssue {
  id            String   @id @default(cuid())
  title         String
  issueNumber   String?
  publishedAt   DateTime @default(now())
  coverImageUrl String
  targetUrl     String?
  priceCzk      Int?
  isCurrent     Boolean  @default(false)
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isCurrent, publishedAt])
}

model AdPlacement {
  id             String            @id @default(cuid())
  placementKey   String            @default("homepage_strip")
  name           String
  productType    AdProductType     @default(PAID_AD)
  location       String
  format         String
  clientName     String?
  creativeUrl    String?
  targetUrl      String?
  priceCzk       Int
  durationDays   Int
  availableSlots Int               @default(1)
  status         AdPlacementStatus @default(AVAILABLE)
  startsAt       DateTime?
  endsAt         DateTime?
  isFeatured     Boolean           @default(false)
  note           String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status, startsAt, endsAt])
  @@index([isFeatured, status])
  @@index([placementKey, status])
  @@index([productType, status])
}
